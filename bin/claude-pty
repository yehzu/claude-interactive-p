#!/usr/bin/env bash
# claude-pty: run interactive Claude under a PTY, auto-submit a prompt, and
# emit a JSON envelope on stdout when the turn finishes.
#
# Envelope shape: superset of `claude -p --output-format=json`, minus ttft_ms
# (not surfaced by any hook or statusline channel), plus statusline-exclusive
# fields (rate_limits, context_window, etc).
#
# Usage:
#   claude-pty [claude flags...] "prompt"
#
# Reads the same Claude Code config as `claude` itself: default ~/.claude,
# or override via CLAUDE_CONFIG_DIR. The Stop hook and statusline shim must
# already be wired into that config (run install.sh once).
set -euo pipefail

# A claude-pty call only makes sense when there is something for claude to
# auto-submit. Without a prompt, the TUI launches and sits idle waiting on
# stdin that never arrives, and the Stop hook never fires. Reject early.
if [ "$#" -eq 0 ]; then
  echo "claude-pty: missing prompt" >&2
  echo "Usage: claude-pty [claude flags...] \"prompt\"" >&2
  exit 2
fi

# Info-only flags: hand them straight to claude (no PTY, no envelope). claude
# prints its own output and exits cleanly, which is what the user asked for.
# --bare: explicitly incompatible. From claude's own help: "skip hooks, LSP,
# plugin sync...". No hooks means the Stop hook can't fire, which means we'd
# hang forever waiting for an envelope that never lands.
for arg in "$@"; do
  case "$arg" in
    --help|-h|--version|-v)
      exec claude "$@"
      ;;
    --bare)
      echo "claude-pty: --bare disables claude's hook system, which we" >&2
      echo "           depend on. Run claude directly instead, or drop --bare." >&2
      exit 2
      ;;
  esac
done

# If the last arg starts with `-`, it's a flag with no prompt after it, which
# would launch the TUI with nothing to auto-submit (the `--bare` case). This
# heuristic doesn't catch a flag-that-takes-a-value as the last arg (e.g.
# `--model haiku` with no prompt would still hang), but it covers the common
# slip. A real fix would require knowing claude's full flag spec.
last_arg="${!#}"
case "$last_arg" in
  -*)
    echo "claude-pty: last argument is a flag ($last_arg), not a prompt" >&2
    echo "Usage: claude-pty [claude flags...] \"prompt\"" >&2
    exit 2
    ;;
esac

tmp_dir=$(mktemp -d -t claude-pty.XXXXXX)
lock_dir="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/.pty-lock"
release_pid=""
# Cleanup releases our lock only if it's still ours — once the early-release
# watcher hands the lock off to a sibling, that sibling's PID is in
# $lock_dir/pid and we must not blow it away on our EXIT.
cleanup() {
  rm -rf "$tmp_dir" 2>/dev/null || true
  if [ -n "$release_pid" ]; then
    kill "$release_pid" 2>/dev/null || true
    wait "$release_pid" 2>/dev/null || true
  fi
  if [ -d "$lock_dir" ]; then
    local holder=""
    holder=$(cat "$lock_dir/pid" 2>/dev/null || true)
    if [ "$holder" = "$$" ]; then
      rm -rf "$lock_dir" 2>/dev/null || true
    fi
  fi
}
trap cleanup EXIT

export CLAUDE_PTY_ENVELOPE="$tmp_dir/envelope.json"
export CLAUDE_PTY_SIDECAR="$tmp_dir/sidecar.json"
export CLAUDE_PTY_DEBUG_LOG="${CLAUDE_PTY_DEBUG_LOG:-$tmp_dir/debug.log}"
# Where `script` records claude's PTY session (script-PTY mode). Captured to a
# file instead of /dev/null so a failure that claude prints to its terminal —
# e.g. `claude --resume` rejecting a missing session with "No conversation
# found" — survives for the failure dump below instead of vanishing.
pty_typescript="$tmp_dir/pty_typescript"

# Stall detection: a turn that never starts (login wizard, usage-limit notice,
# permission dialog) leaves the TUI static and the Stop hook never fires — so
# polling for the envelope would hang forever. Treat "screen unchanged for
# CLAUDE_PTY_STALL_SEC seconds with no envelope" as a dead turn: kill claude
# and emit an error envelope whose result carries the last visible screen
# lines, so the caller sees WHY (e.g. the rate-limit notice). An active turn
# repaints continuously (spinner, token counter), so a healthy run never trips
# this even mid-thought. Set CLAUDE_PTY_STALL_SEC=0 to disable.
stall_file="$tmp_dir/stalled"
stall_max="${CLAUDE_PTY_STALL_SEC:-45}"

# Serialize ONLY claude's supervisor startup race. Claude's TUI mode races
# on a singleton supervisor lock during the first ~1s of boot; two TUIs
# starting simultaneously leave one (or both) hung. Once a claude is past
# that window, additional claudes can run in parallel without conflict.
# So we acquire a mkdir-based lock to gate startup, then release it as
# soon as our claude reaches steady state — signalled by the statusline
# shim writing CLAUDE_PTY_SIDECAR — so the next caller can start its own
# claude while ours keeps running.
#
# Stale-lock recovery: holder PID's liveness is checked via kill -0, so a
# SIGKILL'd run doesn't deadlock successors. Tuning knobs:
#   CLAUDE_PTY_LOCK_WAIT_SEC  total wait at acquire (default 600s)
#   CLAUDE_PTY_LOCK_HOLD_SEC  max hold after acquire if the sidecar
#                              never appears (default 10s)
#   CLAUDE_PTY_NO_LOCK=1      skip the lock entirely. Use when the caller
#                              already guarantees serial startup (e.g. it
#                              runs no statusline shim, so the sidecar signal
#                              never arrives and the lock would only ever
#                              release on the hard timeout).
acquire_startup_lock() {
  [ "${CLAUDE_PTY_NO_LOCK:-0}" = "1" ] && return 0
  local wait_max="${CLAUDE_PTY_LOCK_WAIT_SEC:-600}"
  local start_epoch
  start_epoch=$(date +%s)
  local holder=""
  while true; do
    if mkdir "$lock_dir" 2>/dev/null; then
      printf '%s\n' "$$" > "$lock_dir/pid"
      return 0
    fi
    # Stale lock: if the holder PID file is readable and the PID is dead,
    # take ownership. Empty PID file means an in-progress acquire raced;
    # leave it alone and retry.
    if [ -f "$lock_dir/pid" ]; then
      holder=$(cat "$lock_dir/pid" 2>/dev/null || true)
      if [ -n "$holder" ] && ! kill -0 "$holder" 2>/dev/null; then
        rm -rf "$lock_dir" 2>/dev/null || true
        continue
      fi
    fi
    local now
    now=$(date +%s)
    if [ $((now - start_epoch)) -ge "$wait_max" ]; then
      echo "claude-pty: lock wait timeout after ${wait_max}s (holder pid=${holder:-unknown})" >&2
      echo "claude-pty: set CLAUDE_PTY_LOCK_WAIT_SEC to wait longer, or CLAUDE_PTY_NO_LOCK=1 to skip" >&2
      exit 1
    fi
    # Tight poll: typical hold is ~500ms, so a 500ms poll could waste nearly
    # the whole win waiting to notice the lock free. 50ms keeps the acquire
    # gap to one tick.
    sleep 0.05
  done
}

# Background watcher: hand the lock off to the next caller as soon as our
# claude reaches steady state. The signal is the statusline sidecar file
# appearing (statusline.sh writes it ~500ms after first tick). Falls back
# to a hard timeout in case the statusline isn't wired.
release_lock_after_startup() {
  [ "${CLAUDE_PTY_NO_LOCK:-0}" = "1" ] && return 0
  local hold_max="${CLAUDE_PTY_LOCK_HOLD_SEC:-10}"
  local ticks_max=$((hold_max * 10))
  local ticks=0
  while [ "$ticks" -lt "$ticks_max" ]; do
    if [ -f "$CLAUDE_PTY_SIDECAR" ]; then
      break
    fi
    sleep 0.1
    ticks=$((ticks + 1))
  done
  # Only release if the lock is still ours; a SIGKILL'd predecessor could
  # have had its lock stolen by a sibling already.
  local holder=""
  if [ -d "$lock_dir" ]; then
    holder=$(cat "$lock_dir/pid" 2>/dev/null || true)
    if [ "$holder" = "$$" ]; then
      rm -rf "$lock_dir" 2>/dev/null || true
    fi
  fi
}

# Wall-clock timer for duration_ms. If python3 isn't available, emit JSON
# null in the envelope rather than lying with 0.
now_ms() { python3 -c 'import time; print(int(time.time()*1000))' 2>/dev/null || true; }

pty_log() {
  [ -n "${CLAUDE_PTY_DEBUG_LOG:-}" ] \
    && printf '%s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$*" >> "$CLAUDE_PTY_DEBUG_LOG" \
    || true
}

# Run claude under a PTY, wait for the turn to finish, then terminate claude.
#
# Turn completion is signalled by the Stop hook writing $CLAUDE_PTY_ENVELOPE.
# claude itself does NOT exit at turn end (the interactive TUI waits for more
# input), so this launches it in the background, polls for the envelope, and
# kills it. Version-proof: the old model had the Stop hook `kill $PPID`, which
# broke once Claude Code started wrapping hook commands in a shell (PPID =
# wrapper, not claude) — claude survived, this blocked forever, trees leaked
# as orphans. Owning the kill here means we know the real child pid (and, in
# tmux mode, the session).
#
# Default PTY: `script` with the rendered TUI thrown at /dev/null. When
# CLAUDE_PTY_TMUX_SESSION is set and tmux is available, host the PTY in a
# detached tmux session of that name instead, so an operator can `tmux attach`
# and watch the live UI.
#
# tmux caps a command at a few KB ("command too long"), and both the rendered
# prompt and a full -e environment blow past that. So we keep the tmux command
# tiny: a generated launcher script is the only argument. The launcher restores
# the full environment (sourceable `export -p` dump — so claude resolves the
# same PATH/credentials it would under `script`), cd's to the workspace, and
# execs claude with the prompt read from a file. Any tmux failure falls back to
# the script PTY so a tmux hiccup never costs a turn.
run_claude_pty() {
  if [ -n "${CLAUDE_PTY_TMUX_SESSION:-}" ] && command -v tmux > /dev/null 2>&1; then
    local claude_bin
    claude_bin=$(command -v claude 2>/dev/null || true)
    if [ -n "$claude_bin" ]; then
      local launch="$tmp_dir/launch.sh" promptfile="$tmp_dir/prompt" envfile="$tmp_dir/env.sh"
      printf '%s' "${!#}" > "$promptfile" # last positional arg is the prompt
      export -p > "$envfile"              # full env, safely quoted + sourceable
      {
        printf '#!/usr/bin/env bash\n'
        printf '. %q\n' "$envfile"
        printf 'cd %q 2>/dev/null || true\n' "$PWD"
        printf 'exec %q' "$claude_bin"
        local fl
        for fl in "${@:1:$#-1}"; do printf ' %q' "$fl"; done # flags (all but prompt)
        printf ' "$(cat %q)"\n' "$promptfile"
      } > "$launch"
      chmod +x "$launch"
      tmux kill-session -t "$CLAUDE_PTY_TMUX_SESSION" 2>/dev/null || true
      if tmux new-session -d -c "$PWD" -s "$CLAUDE_PTY_TMUX_SESSION" "$launch" 2> "$tmp_dir/tmux_err"; then
        pty_log "tmux session live: tmux attach -t $CLAUDE_PTY_TMUX_SESSION"
        # Wait for the turn (envelope), claude crashing (session vanishes), or
        # a stalled screen (pane content frozen past the stall budget). On
        # stall, snapshot the pane into $pty_typescript so the failure path
        # below can surface what claude was showing.
        local last_sig="" sig="" stall_ticks=0
        while [ ! -f "$CLAUDE_PTY_ENVELOPE" ] && tmux has-session -t "$CLAUDE_PTY_TMUX_SESSION" 2>/dev/null; do
          sleep 0.2
          if [ "$stall_max" -gt 0 ]; then
            sig=$(tmux capture-pane -p -t "$CLAUDE_PTY_TMUX_SESSION" 2>/dev/null | cksum 2>/dev/null || true)
            if [ -n "$sig" ] && [ "$sig" = "$last_sig" ]; then
              stall_ticks=$((stall_ticks + 1))
              if [ "$stall_ticks" -ge $((stall_max * 5)) ]; then
                tmux capture-pane -p -t "$CLAUDE_PTY_TMUX_SESSION" > "$pty_typescript" 2>/dev/null || true
                : > "$stall_file"
                pty_log "stall: pane frozen for ${stall_max}s with no envelope; giving up"
                break
              fi
            else
              stall_ticks=0
              last_sig="$sig"
            fi
          fi
        done
        # Snapshot the pane's last screen before reaping it, so a resume error
        # or crash message claude printed survives in the debug log instead of
        # dying with the session (tmux mode has no typescript file).
        pty_log "final pane: $(tmux capture-pane -p -t "$CLAUDE_PTY_TMUX_SESSION" 2>/dev/null | grep -v '^[[:space:]]*$' | tail -5 | tr '\n' '|')"
        # kill-session reaps the pane's claude — no orphan, no $PPID guesswork.
        tmux kill-session -t "$CLAUDE_PTY_TMUX_SESSION" 2>/dev/null || true
        pty_log "tmux session closed"
        return 0
      fi
      pty_log "tmux new-session failed ($(tr -d '\n' < "$tmp_dir/tmux_err" 2>/dev/null)); falling back to script PTY"
    else
      pty_log "claude not on PATH for tmux exec; falling back to script PTY"
    fi
  fi

  # script PTY, backgrounded so we can poll for the envelope and then kill the
  # claude it spawned (script's direct child). TERM then KILL guarantees exit
  # even if claude ignores TERM; killing claude makes `script` exit too.
  # The typescript goes to a file (not /dev/null) so claude's own terminal
  # output is recoverable when no envelope is produced (see the failure dump).
  # -t 0 flushes every write, so stall detection (file size+mtime frozen past
  # the stall budget) tracks the real screen, not the default 30s flush cycle.
  script -q -t 0 "$pty_typescript" claude "$@" > /dev/null 2>&1 &
  local pty_pid=$!
  local last_sig="" sig="" stall_ticks=0
  while [ ! -f "$CLAUDE_PTY_ENVELOPE" ] && kill -0 "$pty_pid" 2>/dev/null; do
    sleep 0.2
    if [ "$stall_max" -gt 0 ]; then
      sig=$(stat -f '%z %m' "$pty_typescript" 2>/dev/null || stat -c '%s %Y' "$pty_typescript" 2>/dev/null || true)
      if [ "$sig" = "$last_sig" ]; then
        stall_ticks=$((stall_ticks + 1))
        if [ "$stall_ticks" -ge $((stall_max * 5)) ]; then
          : > "$stall_file"
          pty_log "stall: no PTY output for ${stall_max}s with no envelope; giving up"
          break
        fi
      else
        stall_ticks=0
        last_sig="$sig"
      fi
    fi
  done
  local kid
  for kid in $(pgrep -P "$pty_pid" 2>/dev/null); do kill -TERM "$kid" 2>/dev/null || true; done
  kill -TERM "$pty_pid" 2>/dev/null || true
  sleep 0.3
  for kid in $(pgrep -P "$pty_pid" 2>/dev/null); do kill -KILL "$kid" 2>/dev/null || true; done
  kill -KILL "$pty_pid" 2>/dev/null || true
  wait "$pty_pid" 2>/dev/null || true
  pty_log "script PTY terminated"
  return 0
}

acquire_startup_lock
if [ "${CLAUDE_PTY_NO_LOCK:-0}" != "1" ]; then
  release_lock_after_startup &
  release_pid=$!
fi

# Measured from just before claude starts (after lock acquire), so lock-wait
# time never inflates duration_ms.
start_ms=$(now_ms)

set +e
run_claude_pty "$@"
rc=$?
set -e

end_ms=$(now_ms)
if [ -n "$start_ms" ] && [ -n "$end_ms" ]; then
  duration_ms=$(( end_ms - start_ms ))
else
  duration_ms=null
fi

if [ ! -f "$CLAUDE_PTY_ENVELOPE" ]; then
  terminal_reason="no_envelope"
  [ -f "$stall_file" ] && terminal_reason="stalled"
  # claude's own terminal output usually names the cause (a usage-limit notice,
  # a login wizard, "No conversation found" on a bad resume). Strip ANSI/CR so
  # it's readable rather than buried in TUI escapes. Captured in script-PTY
  # mode always, and in tmux mode when the stall watcher snapshotted the pane.
  #
  # Strip CSI (incl. private <>=? params), OSC (BEL- *and* ST/ESC-\\-
  # terminated), and charset-select escapes, then drop any remaining control
  # bytes (keep tab/newline) so leftover escape fragments and echoed ^D
  # don't clutter the message. Trailing `|| true` is load-bearing: under the
  # active `set -e`/`pipefail`, a stage exiting non-zero (e.g. grep matching
  # nothing, or a SIGPIPE) would otherwise abort the run before the failure
  # is reported — the opposite of diagnosing it.
  screen_tail=""
  if [ -s "$pty_typescript" ]; then
    screen_tail=$(tail -c 4000 "$pty_typescript" \
      | LC_ALL=C sed $'s/\x1b\\[[0-9;?<>=]*[a-zA-Z]//g; s/\x1b\\][^\x1b\x07]*\x1b\\\\//g; s/\x1b\\][^\x07]*\x07//g; s/\x1b[()][0-9A-Za-z]//g' \
      | LC_ALL=C tr -d '\000-\010\013-\037' \
      | grep -v '^[[:space:]]*$' | tail -20 || true)
  fi
  {
    echo "claude-pty: no envelope produced (claude rc=$rc, reason=$terminal_reason)"
    [ -n "$screen_tail" ] && { echo "--- claude output (tail) ---"; printf '%s\n' "$screen_tail"; }
    [ -f "$CLAUDE_PTY_DEBUG_LOG" ] && { echo "--- debug log ---"; cat "$CLAUDE_PTY_DEBUG_LOG"; }
  } >&2
  # Machine-parseable failure on stdout, mirroring the `claude -p
  # --output-format=json` error shape, so callers that parse the envelope get
  # the reason (e.g. the rate-limit notice in .result) instead of empty stdout.
  jq -n \
    --arg result "${screen_tail:-claude produced no output before the turn was abandoned}" \
    --arg reason "$terminal_reason" \
    --argjson dur "$duration_ms" '
    {
      type:               "result",
      subtype:            "error_during_execution",
      is_error:           true,
      api_error_status:   null,
      result:             $result,
      terminal_reason:    $reason,
      stop_reason:        null,
      num_turns:          0,
      duration_ms:        $dur,
      duration_api_ms:    null,
      ttft_ms:            null,
      total_cost_usd:     null,
      usage:              null,
      modelUsage:         {},
      permission_denials: [],
      uuid:               null
    }
  '
  exit 1
fi

# Enrich from the transcript JSONL — best-effort. Do NOT assume it's complete:
# an interactive turn may not have flushed the conversation by the time we kill
# claude (claude buffers it in interactive mode; only `claude -p` writes
# per-event), so this file can hold just metadata. Missing facts stay at the
# defaults below rather than failing the run.
transcript_path=$(jq -r '.transcript_path // empty' "$CLAUDE_PTY_ENVELOPE")
tx_facts='{"num_turns":0,"stop_reason":null,"usage":null,"uuid":null,"modelUsage":{}}'

if [ -n "$transcript_path" ] && [ -f "$transcript_path" ]; then
  tx_facts=$(jq -s '
    (map(select(.type=="assistant"))) as $asst
    | ($asst | last // {}) as $last_asst
    | {
        num_turns:   ($asst | length),
        stop_reason: ($last_asst.message.stop_reason // null),
        usage:       ($last_asst.message.usage // null),
        uuid:        ($last_asst.uuid // $last_asst.message.id // null),
        modelUsage: (
          $asst
          | map({model: (.message.model // "unknown"), u: (.message.usage // {})})
          | group_by(.model)
          | map({
              key: .[0].model,
              value: {
                inputTokens:              (map(.u.input_tokens               // 0) | add),
                outputTokens:             (map(.u.output_tokens              // 0) | add),
                cacheReadInputTokens:     (map(.u.cache_read_input_tokens    // 0) | add),
                cacheCreationInputTokens: (map(.u.cache_creation_input_tokens // 0) | add),
                webSearchRequests:        (map(.u.server_tool_use.web_search_requests // 0) | add)
              }
            })
          | from_entries
        )
      }
  ' "$transcript_path")
fi

# Final envelope: -p shape + statusline subtree + new fields.
jq -n \
  --argjson draft "$(cat "$CLAUDE_PTY_ENVELOPE")" \
  --argjson tx "$tx_facts" \
  --argjson dur "$duration_ms" '
  $draft + {
    is_error:           false,
    api_error_status:   null,
    stop_reason:        $tx.stop_reason,
    num_turns:          $tx.num_turns,
    duration_ms:        $dur,
    duration_api_ms:    ($draft.statusline.cost.total_api_duration_ms // null),
    ttft_ms:            null,
    total_cost_usd:     ($draft.statusline.cost.total_cost_usd // null),
    usage:              $tx.usage,
    modelUsage:         $tx.modelUsage,
    permission_denials: [],
    terminal_reason:    "completed",
    fast_mode_state:    (if ($draft.statusline.fast_mode // false) then "on" else "off" end),
    uuid:               $tx.uuid
  }
'
